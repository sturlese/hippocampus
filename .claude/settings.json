{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f \"$CLAUDE_PROJECT_DIR/wiki/hot.md\" ] && cat \"$CLAUDE_PROJECT_DIR/wiki/hot.md\" || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/on-stop.sh\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(python3 .claude/tools/vault_lint.py*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(mv inbox/*)"
    ]
  }
}
